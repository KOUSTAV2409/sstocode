# Copy this file to .env.local and fill in your values
# cp .env.local.example .env.local

# Provider order (when multiple keys are set): direct Google Gemini first, then OpenRouter, then Mistral.
# Matches the original “Gemini-only” quality path whenever GEMINI_API_KEY is present.

# OpenRouter (unified API, many models). Get a key at https://openrouter.ai/keys
# Uses vision models: google/gemini-2.5-flash, then fallbacks — see src/lib/openrouter-provider.ts
OPENROUTER_API_KEY=

# Optional: max output tokens per OpenRouter request (default 8192). Raise if you have credits; lower if you hit "can only afford N tokens".
# OPENROUTER_MAX_TOKENS=8192

# Optional: Mistral (Pixtral vision for screenshots). Get a key at https://console.mistral.ai/
# See src/lib/mistral-provider.ts for model chain (pixtral-12b-2409, pixtral-large-latest)
MISTRAL_API_KEY=
# Optional: max output tokens per Mistral request (default 8192, same idea as OPENROUTER_MAX_TOKENS)
# MISTRAL_MAX_TOKENS=8192

# Optional: direct Google Gemini (used if OpenRouter fails or if you only set this)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: OpenRouter app attribution (https://openrouter.ai/docs/app-attribution)
# OPENROUTER_HTTP_REFERER=https://your-site.example
